import java.util.*;

class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int[] arr = new int[n];

        for(int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }

        int target = sc.nextInt();
        int ans = -1;

        for(int i = 0; i < n; i++) {
            if(arr[i] == target) {
                ans = i;   // 0-based index
                break;
            }
        }

        if(ans == -1) {
            System.out.println("-1");
        } else {
            System.out.printf("Door Number is %03d-DN", ans);
        }
    }
}
